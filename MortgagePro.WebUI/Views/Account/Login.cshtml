@{
    ViewData["Title"] = "Logowanie";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logowanie - Mortgage Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 flex items-center justify-center h-screen">
    <div class="bg-white p-8 rounded-xl shadow-md border border-slate-200 w-full max-w-md">
        <h2 class="text-2xl font-bold text-slate-800 mb-6 text-center">Logowanie do Systemu</h2>
        @if (ViewBag.Error != null)
        {
            <div class="bg-rose-50 text-rose-600 p-3 rounded-lg text-sm mb-4">@ViewBag.Error</div>
        }
        <form asp-action="Login" method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-1">E-mail</label>
                <input type="email" name="email" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-600 mb-1">Hasło</label>
                <input type="password" name="password" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />
            </div>
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2 px-4 rounded-lg shadow transition">Zaloguj się</button>
        </form>
        <p class="mt-4 text-center text-sm text-slate-500">Nie masz konta? <a href="/Account/Register" class="text-indigo-600 font-semibold hover:underline">Zarejestruj się</a></p>
        <div class="mt-4 text-center">
            <a href="/" class="text-sm text-slate-400 hover:text-slate-600 border-b border-slate-200 pb-1">Powrót do strony głównej</a>
        </div>
    </div>
</body>
</html>

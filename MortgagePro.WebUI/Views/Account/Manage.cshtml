@{
    ViewData["Title"] = "Zarządzanie Kontem";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Konto Użytkownika - Mortgage Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased flex h-screen overflow-hidden">
    
    <aside class="w-64 bg-slate-900 border-r border-slate-800 flex flex-col hidden md:flex text-slate-300 shrink-0">
        <div class="h-16 flex items-center px-6 border-b border-slate-800">
            <span class="text-xl font-bold text-white tracking-tight">Mortgage Pro</span>
        </div>
        <nav class="flex-1 overflow-y-auto py-4">
            <ul class="space-y-1">
                <li>
                    <a href="/" class="flex items-center px-6 py-3 hover:bg-slate-800 hover:text-white transition-colors">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                        Strona Główna
                    </a>
                </li>
                <li>
                    <a href="/Home/Simulator" class="flex items-center px-6 py-3 hover:bg-slate-800 hover:text-white shadow-sm transition-colors">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                        Symulator
                    </a>
                </li>
                <li>
                    <a href="/Home/Documentation" class="flex items-center px-6 py-3 hover:bg-slate-800 hover:text-white transition-colors">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Dokumentacja
                    </a>
                </li>
                <li>
                    <a href="/Account/Manage" class="flex items-center px-6 py-3 bg-indigo-600 text-white font-medium shadow-sm transition-colors">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        Konto Użytkownika
                    </a>
                </li>
            </ul>
        </nav>
        <div class="border-t border-slate-800">
            <ul class="space-y-1 p-4">
                @if (User.Identity!.IsAuthenticated)
                {
                    <li>
                        <a href="/Account/Manage" class="flex items-center px-4 py-2 hover:bg-slate-800 hover:text-indigo-300 transition-colors text-sm rounded-md font-medium">Zarządzanie kontem</a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a href="/Admin/Index" class="flex items-center px-4 py-2 hover:bg-slate-800 text-rose-400 hover:text-rose-300 transition-colors text-sm rounded-md font-semibold">Panel Admina</a>
                        </li>
                    }
                    <li>
                        <form method="post" asp-controller="Account" asp-action="Logout" class="inline w-full">
                            <button type="submit" class="w-full text-left flex items-center px-4 py-2 hover:bg-slate-800 text-slate-400 hover:text-white transition-colors text-sm rounded-md">Wyloguj się</button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto p-4 md:p-8">
        <div class="max-w-2xl mx-auto">
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight mb-6">Zarządzanie kontem</h1>
            
            <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
                <h2 class="text-xl font-bold text-slate-700 mb-6">Zmiana hasła</h2>
                
                @if (ViewBag.Success != null)
                {
                    <div class="mb-4 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded">
                        @ViewBag.Success
                    </div>
                }
                
                @if (ViewBag.Error != null)
                {
                    <div class="mb-4 bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded">
                        @ViewBag.Error
                    </div>
                }

                <form method="post" asp-controller="Account" asp-action="Manage" class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-600 mb-1">Obecne hasło</label>
                        <input type="password" name="currentPassword" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-600 mb-1">Nowe hasło</label>
                        <input type="password" name="newPassword" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition" required />
                    </div>
                    
                    <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-4 rounded-lg shadow transition-colors">
                        Zmień hasło
                    </button>
                </form>
            </div>
            
                </div>
            </div>
            
            <!-- Auth Buttons on Bottom -->
        </div>
    </main>

</body>
</html>

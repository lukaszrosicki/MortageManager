<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('liteSimulator', () => ({
            isConnected: false,
            connection: null,
            schedule: [],
            baselineInterest: 0,
            
            form: {
                amount: 500000,
                months: 360,
                rate: 6.5,
                overpayment: 1000,
                isDecreasing: "false"
            },

            get totalInterest() { return this.schedule.reduce((acc, row) => acc + row.interestPortion, 0); },
            get savings() { return Math.max(0, this.baselineInterest - this.totalInterest); },
            get shortenedMonths() { return Math.max(0, this.form.months - this.schedule.length); },

            computeBaseline(amount, months, rate, isDecreasing) {
                let monthlyRate = rate / 100 / 12;
                if (monthlyRate === 0) return 0;
                if (String(isDecreasing) === "true") {
                    let totalInterest = 0;
                    let princ = amount / months;
                    let remaining = amount;
                    for(let i=0; i<months; i++){
                        totalInterest += remaining * monthlyRate;
                        remaining -= princ;
                    }
                    return totalInterest;
                } else {
                    let baseInst = amount * monthlyRate * Math.pow(1 + monthlyRate, months) / (Math.pow(1 + monthlyRate, months) - 1);
                    return (baseInst * months) - amount;
                }
            },

            init() {
                this.connection = new signalR.HubConnectionBuilder()
                    .withUrl("/mortgageHub")
                    .withAutomaticReconnect()
                    .build();

                this.connection.on("ScheduleUpdated", (newSchedule) => {
                    this.schedule = newSchedule;
                });

                this.connection.start().then(() => {
                    this.isConnected = true;
                    this.generateInitial(); 
                }).catch(err => console.error("Błąd SignalR", err));

                this.$watch('form', () => { this.generateInitial(); }, { deep: true });
            },

            generateInitial() {
                if(this.isConnected) {
                    let amount = parseFloat(this.form.amount) || 0;
                    let months = parseInt(this.form.months) || 1;
                    let rate = parseFloat(this.form.rate) || 0;
                    let overpayment = parseFloat(this.form.overpayment) || 0;
                    let isDecreasing = String(this.form.isDecreasing) === "true";
                    
                    this.baselineInterest = this.computeBaseline(amount, months, rate, isDecreasing);
                    this.connection.invoke("InitializeMortgage", amount, months, rate, true, overpayment, isDecreasing, false, null).catch(e => console.log(e));
                }
            },

            formatCurrency(val) { return new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(val); }
        }));
    });
</script>

